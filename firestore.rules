rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin du vieux site Springs (TM cup / RL) — collection `admins` partagée
    // entre les deux repos. Ne gouverne QUE les collections legacy ci-dessous.
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Admin Aedral (le Hub) — collection DÉDIÉE `aedral_admins`, distincte de
    // `admins`. Gouverne les collections du Hub. Un admin du vieux site n'est
    // PAS admin Aedral. Voir scripts/migrate-aedral-admins.mjs.
    function isAedralAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/aedral_admins/$(request.auth.uid));
    }

    function isTeamManager(teamId) {
      let team = get(/databases/$(database)/documents/rl_teams/$(teamId)).data;
      return request.auth.uid == team.managerId ||
             request.auth.uid == team.founderId;
    }

    // Admin de compétition — rôle SCOPÉ au moteur de compétitions Aedral
    // (collection `competition_admins`, nommés par un admin Aedral complet).
    // Un admin Aedral complet est AUTOMATIQUEMENT admin de compétition (sans
    // le OR, Matt serait bloqué). Voir docs/legends-cup-architecture.md §8.
    function isCompetitionAdmin() {
      return request.auth != null && (
        exists(/databases/$(database)/documents/competition_admins/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/aedral_admins/$(request.auth.uid))
      );
    }

    // ── Admins vieux site Springs (TM cup / RL) ──────────────────────────────
    match /admins/{uid} {
      // Chaque user peut lire sa propre entrée (pour savoir s'il est admin)
      allow read: if request.auth != null && request.auth.uid == uid;
      // Personne côté client ne peut écrire — Admin SDK uniquement
      allow write: if false;
    }

    // ── Admins Aedral (le Hub) ───────────────────────────────────────────────
    match /aedral_admins/{uid} {
      // Chaque user peut lire sa propre entrée (pour savoir s'il est admin)
      allow read: if request.auth != null && request.auth.uid == uid;
      // Personne côté client ne peut écrire — Admin SDK uniquement
      allow write: if false;
    }

    // ── Secrets serveur par user (refresh tokens, etc.) ──────────────────────
    // STRICTEMENT serveur — jamais lu ni écrit côté client. Admin SDK uniquement.
    // Sert au refresh_token Discord pour la passe nocturne de sync (cron).
    match /user_secrets/{uid} {
      allow read, write: if false;
    }

    // ── Flags admin-only sur un user (suspectedSmurf, etc.) ─────────────────
    // STRICTEMENT serveur — visible UNIQUEMENT par les admins via l'API. Le
    // joueur ne doit pas savoir qu'il est flaggé (fuirait avant qu'on enquête).
    // Voir docs/rl-rank-verification-plan.md (Lot 5 v2).
    match /user_admin_flags/{uid} {
      allow read, write: if false;
    }

    // ── État cron (pagination cursor entre runs) ────────────────────────────
    // Privé : seul l'Admin SDK depuis les routes cron y écrit/lit. Aucun
    // intérêt côté client. Préfixe `_` = convention "collection système".
    match /_cron_state/{key} {
      allow read, write: if false;
    }

    // ── Signalements de rang RL (Lot 5 — anti-mensonge) ─────────────────────
    // Création/lecture côté client refusées — tout passe par les API routes :
    //   POST /api/profile/[uid]/rank-report  → crée un report
    //   GET  /api/admin/rank-reports         → admin liste les reports
    //   PATCH /api/admin/rank-reports/[id]   → admin résout
    match /rank_reports/{id} {
      allow read, write: if false;
    }

    // ── Demandes de changement de compte Epic (Lot 6) ───────────────────────
    // Idem, tout passe par les API routes (création par joueur, validation admin).
    match /rl_link_change_requests/{id} {
      allow read, write: if false;
    }

    // ── Demandes de changement de compte Riot / Valorant ─────────────────────
    // Compte Valorant verrouillé sur le PUUID (anti-smurf). Création par joueur
    // + validation admin via les API routes (Admin SDK). Jamais d'accès client.
    match /valorant_link_change_requests/{id} {
      allow read, write: if false;
    }

    // ── Springs Hub — Profils joueurs globaux ────────────────────────────────
    // Toutes les écritures passent par les API routes (Admin SDK).
    // Le client ne fait que lire pour les profils publics.
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Springs Hub — Structures ──────────────────────────────────────────────
    // Lecture publique (annuaire). Toutes les écritures via API routes (Admin SDK).
    match /structures/{id} {
      allow read: if true;
      allow write: if false;

      // Shortlist de recrutement (subcollection) — dirigeants only, via API route
      match /shortlist/{playerId} {
        allow read, write: if false;
      }
    }

    // ── Springs Hub — Membres de structure ────────────────────────────────────
    // Toute la logique d'invitation/join passe par les API routes — pas d'écriture client.
    // Lecture : admin OU le user lit sa propre ligne. Les pages publiques qui affichent
    // la liste des membres passent par des API routes (Admin SDK), pas de read client.
    match /structure_members/{id} {
      allow read: if isAedralAdmin() ||
        (request.auth != null && resource.data.userId == request.auth.uid);
      allow write: if false;
    }

    // ── Springs Hub — Sous-équipes ───────────────────────────────────────────
    match /sub_teams/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Springs Hub — Historique d'appartenance (Phase 3 item N) ─────────────
    // Lecture pour tout user connecté ; toutes les écritures via API routes (Admin SDK).
    match /structure_member_history/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Springs Hub — Invitations / demandes de rejoindre ────────────────────
    match /structure_invitations/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Springs Hub — Événements de structure ────────────────────────────────
    // Lecture pour tout user connecté ; toutes les écritures via API routes (Admin SDK).
    match /structure_events/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Springs Hub — Replays (Rocket League) ───────────────────────────────
    // Fichier physique stocké sur R2 (privé). Ici on ne stocke que les métadonnées.
    // Toute la logique d'accès (upload + download signés, delete) passe par les API
    // routes qui vérifient le UserContext. Lecture client désactivée — les listes
    // sont servies par /api/structures/[id]/replays (filtrage par équipe/event).
    match /replays/{id} {
      allow read: if false;
      allow write: if false;
    }

    // ── Springs Hub — Documents staff (contrats, règlements, etc.) ──────────
    // Stockage hiérarchique en dossiers. Accès strict fondateur + cofondateurs.
    // Fichiers sur R2 (privés, signed URLs). Écritures via API routes uniquement.
    match /structure_folders/{id} {
      allow read: if false;
      allow write: if false;
    }
    match /structure_documents/{id} {
      allow read: if false;
      allow write: if false;
    }

    // ── Springs Hub — Présences aux événements ──────────────────────────────
    // Une ligne par couple (eventId, userId). Écritures via API routes.
    match /event_presences/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Springs Hub — Dispos perso MVP2a ────────────────────────────────────
    // Une ligne par (userId, semaine ISO). Écritures via API route.
    match /user_availability/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Springs Hub — Devoirs MVP2b ─────────────────────────────────────────
    // 1 doc par (devoir × assignee). Écritures via API routes (Admin SDK).
    match /structure_todos/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Springs Hub — Templates de devoirs (v2 étape 2) ─────────────────────
    // Recettes pré-remplies pour créer des devoirs rapidement. scope=personal
    // (perso du coach) ou scope=structure (partagé avec tout le staff).
    // Toutes les listes/écritures passent par les API routes (Admin SDK) qui
    // vérifient le UserContext + l'ownership.
    match /structure_todo_templates/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ══ Moteur de compétitions Aedral (Legends Cup & suivantes) ══════════════
    // Schéma : docs/legends-cup-architecture.md §2. Toutes les ÉCRITURES passent
    // par les API routes (Admin SDK) — `allow write: if false` partout. Les
    // lectures publiques ne contiennent AUCUNE donnée personnelle (ni uid, ni
    // snowflake, ni MMR, ni âge) : tout ce qui est sensible vit dans des docs
    // deny-all servis par API.

    // Circuits (Legends Springs Cup = 1 circuit) — classement/barème publics.
    match /circuits/{id} {
      allow read: if true;
      allow write: if false;
    }

    // Équipes de circuit — points/placements publics. Les rosterUids des
    // participations vivent dans la sous-collection privée (snowflakes).
    match /circuit_teams/{id} {
      allow read: if true;
      allow write: if false;

      match /private/{doc} {
        allow read, write: if false;
      }
    }

    // Compétitions — configuration publique (format, planning, statut).
    match /competitions/{id} {
      allow read: if true;
      allow write: if false;
    }

    // Inscriptions — DENY-ALL : le snapshot contient MMR déclarés, âges,
    // Discord IDs et notes de dérogation sur mineurs. La liste publique
    // « équipes inscrites » (nom/tag/logo/pseudos) est servie par API.
    // (Bascule Lot 0 : l'ancienne règle `read: if request.auth != null`
    // n'avait aucun consommateur client — audit 02/07 : 0 doc legacy.)
    match /competition_registrations/{id} {
      allow read, write: if false;
    }

    // Matchs — bracket live public (onSnapshot pendant l'événement). Aucun
    // uid dans le doc public : ACL, room et litiges en sous-collections.
    match /competition_matches/{id} {
      allow read: if true;
      allow write: if false;

      // room (nom/mdp), acl (participantUids/staffUids), dispute (keys R2) :
      // servis par API aux équipes du match + admins compét uniquement.
      match /private/{doc} {
        allow read, write: if false;
      }

      // Fil de discussion du match : capitaines/staff des 2 équipes + admins.
      // Lecture client temps réel via l'ACL ; écriture via API rate-limitée.
      match /messages/{messageId} {
        allow read: if isCompetitionAdmin() || (
          request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/competition_matches/$(id)/private/acl).data.participantUids
        );
        allow write: if false;
      }
    }

    // Admins de compétition — chaque user peut lire sa propre entrée (pour
    // savoir s'il a accès à la console). Nomination via API (admins Aedral).
    match /competition_admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Registre des bans de compétition (joueurs + structures) — DENY-ALL :
    // consulté à l'inscription côté serveur, géré via API admin compét.
    match /competition_bans/{id} {
      allow read, write: if false;
    }

    // Règlements de compétition — publics (page /reglement), versionnés pour
    // la traçabilité légale (quelle version une équipe a acceptée).
    match /rulebooks/{id} {
      allow read: if true;
      allow write: if false;

      match /versions/{version} {
        allow read: if true;
        allow write: if false;
      }
    }

    // ── Springs Hub — Notifications in-app ───────────────────────────────────
    match /notifications/{id} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // ── TM — Participants ─────────────────────────────────────────────────────
    match /participants/{docId} {
      allow read: if true;
      allow create: if request.auth != null && (
        request.resource.data.userId == request.auth.uid || isAdmin()
      );
      allow update: if request.auth != null && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ── TM — Editions, résultats, config ──────────────────────────────────────
    match /editions/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /results/{id} {
      allow read: if true;
      allow create: if isAdmin() ||
        (request.auth != null &&
         request.resource.data.phase == 'inscription' &&
         get(/databases/$(database)/documents/editions/$(request.resource.data.editionId)).data.status == 'inscriptions' &&
         get(/databases/$(database)/documents/participants/$(request.resource.data.playerId)).data.userId == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin() ||
        (request.auth != null &&
         resource.data.phase == 'inscription' &&
         get(/databases/$(database)/documents/participants/$(resource.data.playerId)).data.userId == request.auth.uid);
    }
    match /predictions/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /siteContent/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /cups/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── TM — Finale events (timeline round-by-round, auto-saisie ManiaScript) ──
    // Lecture publique (timeline finale dans le détail édition).
    // Écriture via Admin SDK uniquement (endpoint /api/cup-event, bypass règles).
    match /finale_events/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── RL — Compétitions ──────────────────────────────────────────────────────
    match /rl_competitions/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ── RL — Demandes de modification d'équipe ─────────────────────────────────
    match /rl_team_edit_requests/{id} {
      allow read: if isAdmin();
      allow create: if request.auth != null;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── RL — Équipes ───────────────────────────────────────────────────────────
    match /rl_teams/{id} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        isAdmin() ||
        request.auth.uid == resource.data.founderId ||
        request.auth.uid == resource.data.managerId
      );
      allow delete: if isAdmin();
    }

    // ── RL — Joueurs ───────────────────────────────────────────────────────────
    match /rl_players/{id} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() || (
        request.auth != null &&
        request.auth.token.discordId != null &&
        request.resource.data.discordId == request.auth.token.discordId &&
        request.resource.data.userId == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    // ── RL — Prédicteurs ───────────────────────────────────────────────────────
    match /rl_predictors/{uid} {
      allow read: if request.auth != null;
      allow write: if (request.auth != null && request.auth.uid == uid) || isAdmin();
    }

    // ── RL — Données prédictions par saison ────────────────────────────────────
    match /rl_pred_season/{uid} {
      allow read: if request.auth != null;
      allow write: if (request.auth != null && request.auth.uid == uid) || isAdmin();
    }

    // ── RL — Roster ────────────────────────────────────────────────────────────
    // Lecture publique : la page LAN publique (lan.html) affiche la composition
    // des équipes qualifiées (section "Merci aux équipes"). Aucune donnée
    // sensible : pseudo joueur + rôle in-game uniquement.
    match /rl_roster/{id} {
      allow read: if true;
      allow create: if request.auth != null && (
        isAdmin() || isTeamManager(request.resource.data.teamId)
      );
      allow update: if request.auth != null && (
        isAdmin() || isTeamManager(resource.data.teamId)
      );
      allow delete: if request.auth != null && (
        isAdmin() || isTeamManager(resource.data.teamId)
      );
    }

    // ── RL — Candidatures équipe ───────────────────────────────────────────────
    match /rl_applications/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        isAdmin() || isTeamManager(resource.data.teamId)
      );
      allow delete: if isAdmin();
    }

    // ── RL — Transferts ────────────────────────────────────────────────────────
    match /rl_transfers/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (
        isAdmin() ||
        isTeamManager(request.resource.data.fromTeamId) ||
        isTeamManager(request.resource.data.toTeamId)
      );
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── RL — Inscriptions aux compétitions ─────────────────────────────────────
    match /rl_registrations/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (
        isAdmin() || isTeamManager(request.resource.data.teamId)
      );
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── RL — Matchs ────────────────────────────────────────────────────────────
    match /rl_matches/{id} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if request.auth != null && (
        isAdmin() ||
        isTeamManager(resource.data.homeTeamId) ||
        isTeamManager(resource.data.awayTeamId)
      );
      allow delete: if isAdmin();
    }

    // ── RL — Stats de match ────────────────────────────────────────────────────
    match /rl_match_stats/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── RL — Disponibilités ────────────────────────────────────────────────────
    match /rl_availability/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (
        isAdmin() || isTeamManager(request.resource.data.teamId)
      );
      allow update: if request.auth != null && (
        isAdmin() || isTeamManager(resource.data.teamId)
      );
      allow delete: if request.auth != null && (
        isAdmin() || isTeamManager(resource.data.teamId)
      );
    }

    // ── RL — Stats ─────────────────────────────────────────────────────────────
    match /rl_stats/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ── RL — LAN (config, qualifs, bracket) ────────────────────────────────────
    // Lecture publique : badges qualifiés / page LAN visibles par tous (site
    // cup monthly affiche le séparateur "TOP N — QUALIFIÉS LAN" sans auth).
    match /rl_lan/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── RL — LAN matchs (Suisse + Bracket) ─────────────────────────────────────
    // Lecture publique : page LAN, écrans géants, prédictions.
    // Saisie scores et génération des rounds : admin uniquement.
    match /rl_lan_matches/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── RL — LAN pronostics (1 doc par utilisateur Discord) ────────────────────
    // Lecture publique : leaderboard public sur la page lan-predictions.html.
    // Écriture : utilisateur connecté Discord, sur SON propre doc uniquement.
    // Admin peut tout écrire (recalcul des scores, résolution des paris).
    match /rl_lan_predictions/{uid} {
      allow read: if true;
      allow create, update: if isAdmin() || (request.auth != null && request.auth.uid == uid);
      allow delete: if isAdmin();
    }

    // ── Springs Hub — Journal d'audit des actions structure ────────────────────
    // Écriture : API serveur uniquement (Admin SDK) — voir lib/audit-log.ts.
    // Lecture : admin Springs uniquement. Les dirigeants voient via une API
    // dédiée qui filtre par structureId (pas de read client direct).
    match /structure_audit_logs/{id} {
      allow read: if isAedralAdmin();
      allow write: if false;
    }

    // ── Journal des actions admin ───────────────────────────────────────────────
    match /admin_logs/{id} {
      allow read: if isAedralAdmin();
      allow create: if isAedralAdmin();
      allow update: if false;
      allow delete: if false;
    }

    // ── Springs Hub — Journal d'audit des actions admin (structures + users) ──
    // Écriture : API serveur uniquement (Admin SDK) — voir lib/admin-audit-log.ts.
    // Lecture : admin Springs uniquement.
    match /admin_audit_logs/{id} {
      allow read: if isAedralAdmin();
      allow write: if false;
    }

    // ── Springs Hub — Templates d'annonces Discord ─────────────────────────────
    // Gérées via /api/admin/announce-templates (CRUD). Admin SDK uniquement.
    // Aucune raison pour un client d'y accéder en direct.
    match /announce_templates/{id} {
      allow read, write: if false;
    }

    // ── Springs Hub — Journal des messages ciblés (annonces / relances) ─────────
    // Envoi via /api/admin/messages/send (Admin SDK). Trace qui/quand/segment/stats.
    // Aucun accès client.
    match /admin_messages/{id} {
      allow read, write: if false;
    }

  }
}
