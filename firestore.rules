rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isTeamManager(teamId) {
      let team = get(/databases/$(database)/documents/rl_teams/$(teamId)).data;
      return request.auth.uid == team.managerId ||
             request.auth.uid == team.founderId;
    }

    // ── Admins Springs ──────────────────────────────────────────────────────
    match /admins/{uid} {
      // Chaque user peut lire sa propre entrée (pour savoir s'il est admin)
      allow read: if request.auth != null && request.auth.uid == uid;
      // Personne côté client ne peut écrire — Admin SDK uniquement
      allow write: if false;
    }

    // ── Springs Hub — Profils joueurs globaux ────────────────────────────────
    // Toutes les écritures passent par les API routes (Admin SDK).
    // Le client ne fait que lire pour les profils publics.
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Springs Hub — Structures ──────────────────────────────────────────────
    // Lecture publique (annuaire). Toutes les écritures via API routes (Admin SDK).
    match /structures/{id} {
      allow read: if true;
      allow write: if false;

      // Shortlist de recrutement (subcollection) — dirigeants only, via API route
      match /shortlist/{playerId} {
        allow read, write: if false;
      }
    }

    // ── Springs Hub — Membres de structure ────────────────────────────────────
    // Toute la logique d'invitation/join passe par les API routes — pas d'écriture client.
    match /structure_members/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Springs Hub — Sous-équipes ───────────────────────────────────────────
    match /sub_teams/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Springs Hub — Invitations / demandes de rejoindre ────────────────────
    match /structure_invitations/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Springs Hub — Événements de structure ────────────────────────────────
    // Lecture pour tout user connecté ; toutes les écritures via API routes (Admin SDK).
    match /structure_events/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Springs Hub — Présences aux événements ──────────────────────────────
    // Une ligne par couple (eventId, userId). Écritures via API routes.
    match /event_presences/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Springs Hub — Dispos perso MVP2a ────────────────────────────────────
    // Une ligne par (userId, semaine ISO). Écritures via API route.
    match /user_availability/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Springs Hub — Devoirs MVP2b ─────────────────────────────────────────
    // 1 doc par (devoir × assignee). Écritures via API routes (Admin SDK).
    match /structure_todos/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Springs Hub — Compétitions ────────────────────────────────────────────
    match /competitions/{id} {
      allow read: if true;
      allow write: if false;
    }

    // ── Springs Hub — Inscriptions aux compétitions ───────────────────────────
    // L'inscription passe par une API route qui valide la structure / le solo.
    match /competition_registrations/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Springs Hub — Notifications in-app ───────────────────────────────────
    match /notifications/{id} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // ── TM — Participants ─────────────────────────────────────────────────────
    match /participants/{docId} {
      allow read: if true;
      allow create: if request.auth != null && (
        request.resource.data.userId == request.auth.uid || isAdmin()
      );
      allow update: if request.auth != null && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ── TM — Editions, résultats, config ──────────────────────────────────────
    match /editions/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /results/{id} {
      allow read: if true;
      allow create: if isAdmin() ||
        (request.auth != null &&
         request.resource.data.phase == 'inscription' &&
         get(/databases/$(database)/documents/editions/$(request.resource.data.editionId)).data.status == 'inscriptions' &&
         get(/databases/$(database)/documents/participants/$(request.resource.data.playerId)).data.userId == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin() ||
        (request.auth != null &&
         resource.data.phase == 'inscription' &&
         get(/databases/$(database)/documents/participants/$(resource.data.playerId)).data.userId == request.auth.uid);
    }
    match /predictions/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /siteContent/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /cups/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── RL — Compétitions ──────────────────────────────────────────────────────
    match /rl_competitions/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ── RL — Demandes de modification d'équipe ─────────────────────────────────
    match /rl_team_edit_requests/{id} {
      allow read: if isAdmin();
      allow create: if request.auth != null;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── RL — Équipes ───────────────────────────────────────────────────────────
    match /rl_teams/{id} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        isAdmin() ||
        request.auth.uid == resource.data.founderId ||
        request.auth.uid == resource.data.managerId
      );
      allow delete: if isAdmin();
    }

    // ── RL — Joueurs ───────────────────────────────────────────────────────────
    match /rl_players/{id} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() || (
        request.auth != null &&
        request.auth.token.discordId != null &&
        request.resource.data.discordId == request.auth.token.discordId &&
        request.resource.data.userId == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    // ── RL — Prédicteurs ───────────────────────────────────────────────────────
    match /rl_predictors/{uid} {
      allow read: if request.auth != null;
      allow write: if (request.auth != null && request.auth.uid == uid) || isAdmin();
    }

    // ── RL — Données prédictions par saison ────────────────────────────────────
    match /rl_pred_season/{uid} {
      allow read: if request.auth != null;
      allow write: if (request.auth != null && request.auth.uid == uid) || isAdmin();
    }

    // ── RL — Roster ────────────────────────────────────────────────────────────
    match /rl_roster/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (
        isAdmin() || isTeamManager(request.resource.data.teamId)
      );
      allow update: if request.auth != null && (
        isAdmin() || isTeamManager(resource.data.teamId)
      );
      allow delete: if request.auth != null && (
        isAdmin() || isTeamManager(resource.data.teamId)
      );
    }

    // ── RL — Candidatures équipe ───────────────────────────────────────────────
    match /rl_applications/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        isAdmin() || isTeamManager(resource.data.teamId)
      );
      allow delete: if isAdmin();
    }

    // ── RL — Transferts ────────────────────────────────────────────────────────
    match /rl_transfers/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (
        isAdmin() ||
        isTeamManager(request.resource.data.fromTeamId) ||
        isTeamManager(request.resource.data.toTeamId)
      );
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── RL — Inscriptions aux compétitions ─────────────────────────────────────
    match /rl_registrations/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (
        isAdmin() || isTeamManager(request.resource.data.teamId)
      );
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── RL — Matchs ────────────────────────────────────────────────────────────
    match /rl_matches/{id} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if request.auth != null && (
        isAdmin() ||
        isTeamManager(resource.data.homeTeamId) ||
        isTeamManager(resource.data.awayTeamId)
      );
      allow delete: if isAdmin();
    }

    // ── RL — Stats de match ────────────────────────────────────────────────────
    match /rl_match_stats/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── RL — Disponibilités ────────────────────────────────────────────────────
    match /rl_availability/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (
        isAdmin() || isTeamManager(request.resource.data.teamId)
      );
      allow update: if request.auth != null && (
        isAdmin() || isTeamManager(resource.data.teamId)
      );
      allow delete: if request.auth != null && (
        isAdmin() || isTeamManager(resource.data.teamId)
      );
    }

    // ── RL — Stats ─────────────────────────────────────────────────────────────
    match /rl_stats/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ── RL — LAN brackets ──────────────────────────────────────────────────────
    match /rl_lan/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ── Journal des actions admin ───────────────────────────────────────────────
    match /admin_logs/{id} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if false;
      allow delete: if false;
    }

  }
}
